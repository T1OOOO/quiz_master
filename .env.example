PORT=8090
AUTH_PORT=8092
STORAGE_PORT=8093
AUTH_DB_PATH=/app/data/auth.db
STORAGE_DB_PATH=/app/data/storage.db
ENV=production
QUIZZES_DIR=quizzes
JWT_SECRET=change-me
AUTH_API_TOKEN=dev-auth-token
STORAGE_API_TOKEN=dev-storage-token
AUTH_API_URL=http://auth:8092
STORAGE_API_URL=http://storage:8093
JWT_TTL=24h
SHUTDOWN_TIMEOUT=10s
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_TRACES_SAMPLER_ARG=1
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
